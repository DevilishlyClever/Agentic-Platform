# Database (Neon PostgreSQL)
DATABASE_URL=postgres://user:password@host/dbname

# Admin secret for internal API routes
ADMIN_SECRET=change-me-in-production

# Vercel AI Gateway (OIDC auto-provisioned by Vercel; or set manually for local dev)
# AI_GATEWAY_API_KEY=your-key-here

# Optional: override AI Gateway model
# ANTHROPIC_DEFAULT_SONNET_MODEL=anthropic/claude-sonnet-4.6

# Client ID used to tag leads submitted via public landing-page forms.
# Required for POST /api/v1/leads/public to work.
# Create a client via POST /api/internal/admin/clients, then paste the returned id here.
MARKETING_CLIENT_ID=
